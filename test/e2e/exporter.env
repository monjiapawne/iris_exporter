# Test environment config only, not for production use
# IRIS Target
IRIS_APIKEY=testkey
IRIS_SCHEME=http
IRIS_HOST=app
IRIS_PORT=8000
IRIS_VERIFY_TLS=false

# Exporter
EXPORTER_ADDRESS=0.0.0.0
EXPORTER_PORT=10043
EXPORTER_LOG_LEVEL=debug # {debug|info|warn|error}

# Exporter behavior
EXPORTER_CASES_SPLIT_SUBCLASSES=true
EXPORTER_ALERTS_SPLIT_SUBCLASSES=true
EXPORTER_TASKS_ENABLED=true